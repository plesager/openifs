# Source common environment variables
. ../common/env_vars

# Pre-empt some common namelist settings.
# NAMARG:
CNMEXP="'ham7'"

# NAEPHY:
LEO3CH=".TRUE."
NAEPHY_EXTRA="LO3CH_HLO=.TRUE.,"

# NAMDPHY:
NVEXTR="7"
NCEXTR="137"

# NAMRIP
CSTOP=${CSTOP:-"'t48'"}            # CSTOP: define num. timesteps
TSTEP=${TSTEP:-"1800.000000"}        # TSTEP: define time-step in seconds

# NAMCT0:
NFRPOS=3
# NAMCT0_EXTRA="NSPPR=1,"  # uncomment for per-level norms

# Include common namelists
. ../common/namelists

cp ../common/fort.4-oac-adapted fort.4

